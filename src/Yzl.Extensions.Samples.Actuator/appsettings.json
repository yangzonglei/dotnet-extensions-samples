{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "management": {
    "endpoints": {
      "web": {
        "exposure": {
          "include": [ "health", "info", "metrics", "env", "beans", "loggers", "caches", "mappings", "conditions", "metadata", "httptrace" ],
          "exclude": [],
          "corsOrigins": [ "*" ]
        }
      }
    },
    "endpoint": {
      "shutdown": {
        "enabled": false
      },
      "httptrace": {
        "enabled": true,
        "capacity": 100
      }
    },
    "health": {
      "diskspace": {
        "path": "/",
        "threshold": 10485760
      }
    }
  }
}
