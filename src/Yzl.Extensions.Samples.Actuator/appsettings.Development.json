{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "management": {
    "endpoints": {
      "web": {
        "exposure": {
          "include": [ "health", "info", "metrics", "env", "beans", "loggers", "caches", "mappings", "conditions", "metadata", "httptrace", "shutdown" ]
        }
      }
    },
    "endpoint": {
      "shutdown": {
        "enabled": true
      },
      "httptrace": {
        "enabled": true,
        "capacity": 200
      }
    }
  }
}
