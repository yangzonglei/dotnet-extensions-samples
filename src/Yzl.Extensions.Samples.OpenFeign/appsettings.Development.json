{
  "spring": {
    "application": {
      "name": "Yzl.Extensions.Samples.OpenFeign-Development"
    },
    "feign": {
      "default": {
        "timeout": 5000,
        "retry": {
          "enabled": true,
          "maxAttempts": 2,
          "delayNs": 200
        },
        "hedging": {
          "enabled": false,
          "maxAttempts": 1,
          "delayMs": 150
        },
        "circuitBreaker": {
          "enabled": true,
          "failureRatio": 0.2,
          "samplingSeconds": 30,
          "minimumThroughput": 5,
          "breakSeconds": 20
        }
      },
      "httpClient": {
        "handlerLifetime": "infinite",
        "keepAlive": {
          "enabled": true,
          "pingDelay": "00:00:30",
          "pingTimeout": "00:00:10"
        },
        "pool": {
          "idleTimeout": "00:05:00",
          "connectionLifetime": "00:10:00"
        }
      },
      "basicAuth": {
        "enabled": true,
        "username": "name",
        "password": "pwd"
      }
    }
  },
  "apis": {
    "internal-api-dev": "http://localhost:16062/",
    "internal-api": "http://10.1.24.134:16021/internal-api-v4/",
    "api": "http://localhost:16600/"
  }
}
