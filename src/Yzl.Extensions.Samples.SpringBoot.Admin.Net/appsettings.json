{
  "spring": {
    "application": {
      "name": "yzl-sba-client-samples"
    },
    "boot": {
      "admin": {
        "client": {
          "Url": "http://localhost:16000",
          "Username": "admin",
          "Password": "1",
          "RefreshInterval": "00:00:15",
          "AutoRegistration": true,
          "AutoDeregistration": true
        }
      }
    }
  },
  "management": {
    "server": {
      "port": 26606
    },
    "endpoints": {
      "web": {
        "basePath": "/actuator",
        "exposure": {
          "include1": [ "health", "info", "metrics", "loggers", "caches", "env", "mappings", "conditions", "metadata", "beans", "httptrace", "shutdown" ],
          "exclude1": []
        }
      }
    },
    "endpoint": {
      "shutdown": {
        "enabled": true
      },
      "httptrace": {
        "enabled": true,
        "capacity": 200
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
